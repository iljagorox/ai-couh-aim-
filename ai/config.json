{
  "preferred_language": "ru",
  "vision_model": "gemma3:4b-it-qat",
  "brain_model": "gemma3:4b-it-qat",
  "auto_execute": false,
  "voice_lang": "ru-RU",
  "planner_history_limit": 4,
  "planner_max_steps": 16,
  "browser_planner_max_steps": 40,
  "planner_temperature": 0.4,
  "offline_mode": false,
  "allow_web_search": true,
  "allow_browser_exploration": true,
  "vision_temperature": 0.2,
  "use_search_engine": "https://yandex.ru/search/?text={query}",
  "memory_file": "sentinel_memory.json",
  "memory_limit": 200,
  "aim_temperature": 0.45,
  "aim_coach_poll_sec": 2.5,
  "default_runtime_profile": "desktop",
  "default_game_profile": "Auto Detect",
  "save_screenshots": true,
  "warmup_vision": false,
  "low_memory_mode": true,
  "vision_max_side": 1280,
  "ollama_num_ctx": 2048,
  "ollama_keep_alive": "-1",
  "enable_reasoning": false,
  "reasoning_only_when_stuck": true,
  "aim_extract_insight": true,
  "agent_step_delay_sec": 0.30,
  "ollama_num_predict": 1024,
  "ollama_num_predict_vision": 200,
  "planner_screen_desc_max_chars": 1200,
  "vision_prompt": "Опиши экран кратко на русском: видимые окна, кнопки, текст, примерные координаты.",
  "ollama_num_predict_aim": 200,

  "voice_source_name": "Русский",
  "voice_target_name": "Английский",
  "voice_translator_model": "gemma3:4b-it-qat",
  "voice_font_size": 32,
  "voice_text_color": "#FFA500",
  "voice_bg_alpha": 0.3,
  "voice_auto_hide_seconds": 5,
  "voice_subtitle_font": "Segoe UI",

  "whisper_model_size": "base",
  "whisper_device": "cuda",
  "vad_silence_duration": 0.4,
  "vad_min_speech_duration": 0.2,
  "vad_max_speech_duration": 10.0,
  "ollama_num_predict_voice": 256
}